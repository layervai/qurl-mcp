{
  "name": "@layerv/qurl-mcp",
  "version": "0.1.2",
  "description": "MCP server for QURL - secure link management for AI agents",
  "type": "module",
  "bin": {
    "qurl-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "qurl",
    "layerv",
    "security",
    "ai-agents"
  ],
  "author": "LayerV AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/layervai/qurl-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^10.0.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  }
}
